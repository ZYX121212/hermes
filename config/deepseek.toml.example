# Hermes Agent — DeepSeek Configuration
learning_rate = 0.1
working_memory_size = 100
max_concurrency = 10

[llm]
provider = "deepseek"
model = "deepseek-chat"
max_tokens = 4096
api_key = "${DEEPSEEK_API_KEY}"

[qdrant]
url = "http://localhost:6334"
collection = "hermes_memory"
embedding_dim = 1024

[search]
endpoint = "https://api.search.brave.com/res/v1/web/search"

[scorer]
success_weight = 0.6
latency_weight = 0.2
quality_weight = 0.2
latency_target_ms = 2000
