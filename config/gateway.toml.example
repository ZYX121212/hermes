# Hermess Gateway configuration
[gateway]
listen = "0.0.0.0:9090"
api_key = "sk-gateway-local"
default_mode = "cost-first"

# ── Auto-discovery: auto-register all models from upstream /v1/models ──
# You can add multiple [[gateway.discovery]] blocks for multiple providers.
[[gateway.discovery]]
base_url = "https://api.deepseek.com/v1"
api_key = "${DEEPSEEK_API_KEY}"
provider = "openai"
name_prefix = "deepseek"       # only keep models whose id starts with "deepseek"
default_cost_input = 0.27
default_cost_output = 1.10
default_tags = ["deepseek"]

# ── Static models (optional, takes priority over discovered) ──
# [[gateway.models]]
# name = "custom-model"
# provider = "openai"
# base_url = "https://example.com/v1"
# api_key = "${CUSTOM_API_KEY}"
# cost_per_1m_input = 1.0
# cost_per_1m_output = 2.0
# capability = { reasoning = 0.6, coding = 0.8, creative = 0.5, knowledge = 0.7, speed_ms = 200 }
# tags = ["custom"]

# ── Classifier ──
[gateway.classifier]
model = "deepseek-v4-flash"   # lightweight model for classification
timeout_ms = 2000

# ── SHG ──
[gateway.shg]
enabled = true
prompt_len_threshold = 200
hard_patterns = [
    "时间复杂度",
    "formal proof",
    "prove",
    "security audit",
    "cryptograph",
    "distributed consensus",
]
force_model = "deepseek-v4-pro"   # strong model for hard questions

# ── Token optimizer (optional, disabled by default) ──
[gateway.optimizer]
decompose_enabled = false
distill_enabled = false
distill_keep_ratio = 0.2
