# Hermess — Environment variable template
# Copy to .env and fill in your actual values

# ── LLM API Keys ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# ── Search ────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ── Qdrant (vector memory) ───────────────────────────────
QDRANT_URL=http://localhost:6334

# ── Gateway ───────────────────────────────────────────────
GATEWAY_API_KEY=

# ── Web Daemon ────────────────────────────────────────────
HERMESS_API_KEY=

# ── Financial Data ─────────────────────────────────────────
# Provider: leave empty (null), "sina", "tushare", or "ftshare"
# sina = free real-time quotes, no token needed
HERMESS_FINANCE_PROVIDER=
HERMESS_FINANCE_URL=https://market.ft.tech
HERMESS_TUSHARE_TOKEN=
